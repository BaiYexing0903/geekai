# =============================================================================
# GateHub Docker 镜像构建和推送配置文件
# =============================================================================
# 使用方法:
#   1. 复制此文件为 deploy/push.env
#   2. 修改下面的配置值
#   3. 运行 ./deploy/build-and-push.sh 脚本将自动读取 deploy/push.env
#
# 说明：
#   - 以 # 开头的行为注释
#   - 配置格式：KEY=VALUE（不要有空格）
# =============================================================================

# -----------------------------------------------------------------------------
# Harbor 仓库配置 (必填)
# -----------------------------------------------------------------------------

# Harbor 仓库地址
# 示例：harbor.example.com / registry.cn-beijing.aliyuncs.com / ghcr.io
# 注意：不要添加 /v2 后缀，Docker 会自动添加
# 注意：协议前缀 http:// 或 https:// 通常不需要，除非是本地测试
HARBOR_HOST=harbor.example.com

# Harbor 项目名称
# 注意：该项目需要预先在 Harbor 中创建
# 后端镜像路径：${HARBOR_HOST}/${HARBOR_PROJECT}/gatehub-server
# 前端镜像路径：${HARBOR_HOST}/${HARBOR_PROJECT}/gatehub-frontend
HARBOR_PROJECT=gatehub

# 镜像名称配置
# 后端镜像名称
BACKEND_IMAGE_NAME=gatehub-server
# 前端镜像名称
FRONTEND_IMAGE_NAME=gatehub-frontend

# Harbor 用户名（用于 docker login）
# 如果不需要自动登录，可以留空或注释掉
HARBOR_USERNAME=your_username

# Harbor 密码（用于 docker login）
# ⚠️ 安全提示：请确保此文件不被提交到版本控制系统
HARBOR_PASSWORD=your_password

# -----------------------------------------------------------------------------
# 镜像版本配置 (必填)
# -----------------------------------------------------------------------------

# 镜像版本号
# 建议使用语义化版本号，如：v1.0.0, v1.2.3
# 特殊值：latest (指向最新版本)
VERSION=latest

# 是否同时添加 latest 标签
# true: 同时推送 VERSION 和 latest 标签
# false: 只推送 VERSION 标签
PUSH_LATEST=true

# -----------------------------------------------------------------------------
# 构建配置 (可选)
# -----------------------------------------------------------------------------

# 是否构建前端镜像
# true: 同时构建并推送后端和前端镜像
# false: 只构建并推送后端镜像
BUILD_FRONTEND=false

# Dockerfile 路径（相对于项目根目录）
# 后端 Dockerfile 路径
BACKEND_DOCKERFILE=Dockerfile

# 前端 Dockerfile 路径（相对于项目根目录）
FRONTEND_DOCKERFILE=deploy/frontend/Dockerfile

# -----------------------------------------------------------------------------
# 构建平台配置 (可选，多架构构建)
# -----------------------------------------------------------------------------

# 目标平台架构
# 可选值：linux/amd64, linux/arm64, darwin/amd64, darwin/arm64
# 多个平台使用逗号分隔：linux/amd64,linux/arm64
# 留空表示使用当前平台
BUILD_PLATFORM=

# -----------------------------------------------------------------------------
# 高级配置 (可选)
# -----------------------------------------------------------------------------

# Docker 构建参数
# 可选：--no-cache, --pull, --compress 等
BUILD_ARGS=

# 是否在构建前清理旧镜像
# true: 构建前删除同名的本地镜像
# false: 保留旧镜像
CLEAN_OLD_IMAGES=false

# 是否在推送前测试镜像
# true: 推送前运行简单的容器测试
# false: 直接推送
TEST_BEFORE_PUSH=false
